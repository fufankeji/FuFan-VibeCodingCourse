    {
      "id": "ENzA9ZnxM2Ndf91OVRaUs",
      "type": "text",
      "x": 603.8172604793663,
      "y": 9478.07288183145,
      "width": 280.70550537109375,
      "height": 51.95158447695899,
      "angle": 0,
      "strokeColor": "#c92a2a",
      "backgroundColor": "transparent",
