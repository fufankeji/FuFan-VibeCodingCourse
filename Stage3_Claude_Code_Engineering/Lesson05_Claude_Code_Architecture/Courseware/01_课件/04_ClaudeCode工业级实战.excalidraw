    },
    {
      "id": "y2KsldiNiTkMpdeK3P6KF",
      "type": "text",
      "x": 619.7754348865291,
      "y": 5474.024534482787,
      "width": 181.2735137939453,
      "height": 68.56055973506014,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "strokeStyle": "solid",
      "roughness": 0,
      "opacity": 100,
      "groupIds": [],
      "frameId": "k3RWoVRgPf29bjbM9rDDD",
      "roundness": null,
      "boundElements": [],
      "updated": 1772605842933,
      "link": null,
      "locked": false,
      "versionNonce": 1302345655,
      "isDeleted": false,
      "seed": 284974487,
      "text": "定义当前命令或技能执行时被允许\n调用哪些工具（如 Bash、Read、Write）。\n\n本质是白名单机制，让 Claude 在执行\n命令时不能随意调用未列出的工具，\n从而减少被滥用或误用的风险。",
      "fontSize": 9.141407964674686,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "baseline": 13,
      "containerId": null,
      "originalText": "定义当前命令或技能执行时被允许\n调用哪些工具（如 Bash、Read、Write）。\n\n本质是白名单机制，让 Claude 在执行\n命令时不能随意调用未列出的工具，\n从而减少被滥用或误用的风险。",
      "lineHeight": 1.25,
      "version": 472,
      "index": "b2i",
      "autoResize": true
    },
