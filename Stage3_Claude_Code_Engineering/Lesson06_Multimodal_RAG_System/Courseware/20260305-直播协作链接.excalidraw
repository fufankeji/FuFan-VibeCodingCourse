    {
      "id": "MRn5jBbmdjizMmB6cHbPx",
      "type": "text",
      "x": 707.7111329356566,
      "y": 15145.728403718958,
      "width": 316.79998779296875,
      "height": 420,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "cross-hatch",
      "strokeWidth": 1,
      "strokeStyle": "solid",
      "roughness": 0,
      "opacity": 100,
      "groupIds": [],
