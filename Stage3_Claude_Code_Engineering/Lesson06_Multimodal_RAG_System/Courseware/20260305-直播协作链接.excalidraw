    {
      "id": "gU24aG887gQaDBR25NchV",
      "type": "text",
      "x": 665.5500346995686,
      "y": 8595.639255788608,
      "width": 420.51165771484375,
      "height": 200,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "cross-hatch",
