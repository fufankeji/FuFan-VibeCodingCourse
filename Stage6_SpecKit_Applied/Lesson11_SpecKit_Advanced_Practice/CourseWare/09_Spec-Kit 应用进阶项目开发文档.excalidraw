      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [
        "5LuN6-IZP2XnPosGL02QG"
      ],
      "frameId": null,
      "index": "b0R",
      "roundness": null,
      "seed": 696314757,
