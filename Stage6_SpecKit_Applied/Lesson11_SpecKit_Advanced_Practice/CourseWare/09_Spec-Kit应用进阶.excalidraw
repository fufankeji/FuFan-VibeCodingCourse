    {
      "id": "lzWM3c6Sno_WVxK7Ufq-f",
      "type": "text",
      "x": 2328.2865950956057,
      "y": 8022.288996230088,
      "width": 1739.099365234375,
      "height": 546.75,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "b06V",
      "roundness": null,
      "seed": 692723151,
      "version": 149,
