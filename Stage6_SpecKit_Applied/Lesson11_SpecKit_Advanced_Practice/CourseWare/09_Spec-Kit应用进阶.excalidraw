    {
      "id": "ySQmYFla6TgFJ9wAcFpGA",
      "type": "text",
      "x": 2330,
      "y": 37073.519299214044,
      "width": 1740,
      "height": 367,
      "angle": 0,
      "strokeColor": "#1e1e1e",
