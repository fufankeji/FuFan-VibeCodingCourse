    {
      "id": "N7P4_t94J0oKYJdvS9jZ0",
      "type": "text",
      "x": 217.61571370101552,
      "y": 5221.1464548428285,
      "width": 1631.8046875,
      "height": 465.75,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
