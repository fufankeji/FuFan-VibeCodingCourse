    {
      "id": "UzKIG6n6ECf-FLWXj-tJa",
      "type": "text",
      "x": 524.9140625,
      "y": 8141.913461969745,
      "width": 946.5535278320312,
      "height": 1115.1000000000001,
      "angle": 0,
