    {
      "id": "dOmXAve6tJXllbWAX14-U",
      "type": "text",
      "x": 528,
      "y": 7337.913461969745,
      "width": 1444,
      "height": 718,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "aXV",
