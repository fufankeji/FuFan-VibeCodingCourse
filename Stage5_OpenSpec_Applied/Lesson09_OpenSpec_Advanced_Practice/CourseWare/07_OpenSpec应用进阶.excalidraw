    {
      "id": "S24_text-rules",
      "type": "text",
      "x": 55.05386421217463,
      "y": 19877.268911739608,
      "width": 396,
      "height": 232,
      "angle": 0,
      "text": "📋  自定义验证规则\n通过 config.yaml rules 注入项目级标准\n\nrules:\n  specs: \"Maximum 2000 words per spec\"\n  design: \"Diagram all major flows\"\n  tasks: \"Each task max 2 hours\"\n\nvalidateConfigRules()  验证规则有效性",
      "fontSize": 12,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "strokeColor": "#78350f",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": "S24_frame-s24",
      "roundness": null,
      "seed": 100018,
      "version": 495,
      "versionNonce": 1502648249,
      "isDeleted": true,
      "boundElements": [],
      "updated": 1776222107554,
      "link": null,
      "locked": false,
      "containerId": null,
      "autoResize": false,
      "lineHeight": 1.5,
      "index": "bDW",
      "originalText": "📋  自定义验证规则\n通过 config.yaml rules 注入项目级标准\n\nrules:\n  specs: \"Maximum 2000 words per spec\"\n  design: \"Diagram all major flows\"\n  tasks: \"Each task max 2 hours\"\n\nvalidateConfigRules()  验证规则有效性"
    },
