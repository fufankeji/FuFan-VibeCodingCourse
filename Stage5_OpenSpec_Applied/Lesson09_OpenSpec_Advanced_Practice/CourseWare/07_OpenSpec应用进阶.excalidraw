    },
    {
      "id": "W4FZZcr-x6hNKv0SfuhAF",
      "type": "text",
      "x": 483.4961719675007,
      "y": 7549.48166236727,
      "width": 415,
      "height": 16,
      "angle": 0,
      "text": "📌 Given   用户输入无效密码（用户名存在，密码错误）",
      "fontSize": 12,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "strokeColor": "#e8590c",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "roundness": null,
      "frameId": "W15QS9Gb7xsIaQbWTRGJ0",
      "version": 616,
      "isDeleted": false,
      "boundElements": [],
      "link": null,
      "locked": false,
      "updated": 1776138162309,
      "seed": 917097502,
      "versionNonce": 284377346,
      "originalText": "📌 Given   用户输入无效密码（用户名存在，密码错误）",
      "lineHeight": 1.25,
      "containerId": null,
      "index": "bIN",
      "autoResize": true
    },
    {
      "id": "EsrGPlHjEYUEwuC51uK9q",
      "type": "text",
      "x": 483.4961719675007,
      "y": 7569.48166236727,
      "width": 415,
      "height": 16,
      "angle": 0,
      "text": "▶️  When   POST /login { username, password }",
      "fontSize": 12,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "strokeColor": "#1971c2",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "roundness": null,
      "frameId": "W15QS9Gb7xsIaQbWTRGJ0",
      "version": 616,
      "isDeleted": false,
      "boundElements": [],
      "link": null,
      "locked": false,
      "updated": 1776138162309,
      "seed": 504797278,
      "versionNonce": 145215682,
      "originalText": "▶️  When   POST /login { username, password }",
      "lineHeight": 1.25,
      "containerId": null,
      "index": "bIO",
      "autoResize": true
    },
    {
      "id": "sJd-ajSMj8Qkg1HK-sARz",
      "type": "text",
      "x": 483.4961719675007,
      "y": 7589.48166236727,
      "width": 415,
      "height": 16,
      "angle": 0,
      "text": "✔️  Then   返回 401 + 错误消息",
      "fontSize": 12,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "strokeColor": "#c92a2a",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "roundness": null,
      "frameId": "W15QS9Gb7xsIaQbWTRGJ0",
      "version": 616,
      "isDeleted": false,
      "boundElements": [],
      "link": null,
      "locked": false,
      "updated": 1776138162309,
      "seed": 1319099550,
      "versionNonce": 45377666,
      "originalText": "✔️  Then   返回 401 + 错误消息",
      "lineHeight": 1.25,
      "containerId": null,
      "index": "bIP",
      "autoResize": true
    },
    {
      "id": "xlqPAEU6hroAuwx2mwEM8",
      "type": "text",
      "x": 483.4961719675007,
      "y": 7609.48166236727,
      "width": 415,
      "height": 30,
      "angle": 0,
      "text": "      MUST return { \"message\": \"Invalid credentials\" }\n      MUST NOT 暴露「用户是否存在」的信息",
      "fontSize": 11,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "strokeColor": "#c92a2a",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "roundness": null,
      "frameId": "W15QS9Gb7xsIaQbWTRGJ0",
      "version": 616,
      "isDeleted": false,
      "boundElements": [],
      "link": null,
      "locked": false,
      "updated": 1776138162309,
      "seed": 1576442078,
      "versionNonce": 114821186,
      "originalText": "      MUST return { \"message\": \"Invalid credentials\" }\n      MUST NOT 暴露「用户是否存在」的信息",
      "lineHeight": 1.25,
      "containerId": null,
      "index": "bIQ",
      "autoResize": true
    },
