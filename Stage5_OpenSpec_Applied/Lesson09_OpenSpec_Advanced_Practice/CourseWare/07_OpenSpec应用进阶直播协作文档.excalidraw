    {
      "id": "ItLf4_bGLSmzWR8WsRTMJ",
      "type": "text",
      "x": 508.8222289318776,
      "y": 302.15903418661526,
      "width": 656.519775390625,
      "height": 800,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
