    {
      "id": "zjLg-9AwwFpRV1TeSkj-H",
      "type": "text",
      "x": 1196.0079335580585,
      "y": 424.4176220132407,
      "width": 660.1597900390625,
      "height": 550,
      "angle": 0,
      "strokeColor": "#1e1e1e",
