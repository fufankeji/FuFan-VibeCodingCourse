      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [
        "DHyxWGwKjxV4Dgyc5vAHU"
      ],
      "frameId": null,
      "index": "a5",
