    {
      "id": "nhlJ8KjmksvJa3_24-xdi",
      "type": "text",
      "x": 962.1532803490414,
      "y": 2485.663379560208,
      "width": 465.95166015625,
      "height": 540,
      "angle": 0,
      "strokeColor": "#2f9e44",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [
        "bNIZz4DmxDwqtOSJHG4DL"
      ],
      "frameId": null,
      "index": "aQ",
