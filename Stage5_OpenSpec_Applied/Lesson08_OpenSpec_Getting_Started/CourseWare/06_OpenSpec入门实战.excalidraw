      "seed": 179202,
      "versionNonce": 218770775,
      "originalText": "▶️  When   POST /login { username, password }",
      "lineHeight": 1.25,
      "containerId": null,
      "index": "bCW",
      "autoResize": true
    },
    {
      "id": "S23_card4_then",
      "type": "text",
      "x": 487.4460800742545,
      "y": 16856.165082965334,
      "width": 415,
      "height": 16,
      "angle": 0,
      "text": "✔️  Then   返回 401 + 错误消息",
      "fontSize": 12,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "strokeColor": "#c92a2a",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "roundness": null,
      "frameId": "S23_frame_s23",
      "version": 236,
      "isDeleted": true,
      "boundElements": [],
      "link": null,
      "locked": false,
      "updated": 1775646987188,
      "seed": 334555,
      "versionNonce": 1106982809,
      "originalText": "✔️  Then   返回 401 + 错误消息",
      "lineHeight": 1.25,
      "containerId": null,
      "index": "bCX",
      "autoResize": true
    },
    {
      "id": "S23_card4_must",
      "type": "text",
      "x": 487.4460800742545,
      "y": 16876.165082965334,
      "width": 415,
      "height": 30,
      "angle": 0,
      "text": "      MUST return { \"message\": \"Invalid credentials\" }\n      MUST NOT 暴露「用户是否存在」的信息",
      "fontSize": 11,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "strokeColor": "#c92a2a",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "roundness": null,
      "frameId": "S23_frame_s23",
      "version": 236,
      "isDeleted": true,
      "boundElements": [],
      "link": null,
      "locked": false,
      "updated": 1775646987188,
      "seed": 689148,
      "versionNonce": 1479043703,
      "originalText": "      MUST return { \"message\": \"Invalid credentials\" }\n      MUST NOT 暴露「用户是否存在」的信息",
      "lineHeight": 1.25,
      "containerId": null,
      "index": "bCY",
      "autoResize": true
    },
