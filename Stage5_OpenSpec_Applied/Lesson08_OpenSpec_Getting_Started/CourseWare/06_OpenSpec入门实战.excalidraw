    {
      "id": "6vnJota0gGOCLGljIFsdz",
      "type": "text",
      "x": 1439.5768654300116,
      "y": 6988.430183273533,
      "width": 563.775634765625,
      "height": 620,
      "angle": 0,
      "strokeColor": "#2f9e44",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "bNSV",
