      "y": 16836.165082965334,
      "width": 415,
      "height": 16,
      "angle": 0,
      "text": "▶️  When   POST /login { username, password }",
      "fontSize": 12,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "strokeColor": "#1971c2",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
