    },
    {
      "id": "S11_card3-body",
      "type": "text",
      "x": 520.1686580579425,
      "y": 8484.471661153808,
      "width": 413,
      "height": 178,
      "angle": 0,
      "strokeColor": "#444444",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
