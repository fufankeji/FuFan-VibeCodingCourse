    },
    {
      "id": "r9nUgWLrQg53Ga6eZSVG9",
      "type": "text",
      "x": 979.8845060730036,
      "y": 3743.1558083602686,
      "width": 375.4273069809062,
      "height": 97.8188555213567,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
