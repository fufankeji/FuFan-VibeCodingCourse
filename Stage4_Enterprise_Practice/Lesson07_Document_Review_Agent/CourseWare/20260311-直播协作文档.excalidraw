    {
      "id": "xdKd0oZW1BW12eWPOFfc1",
      "type": "text",
      "x": 947.850233948583,
      "y": 20145.748797749347,
      "width": 660.0199584960938,
      "height": 400,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "#b2f2bb",
      "fillStyle": "hachure",
      "strokeWidth": 1,
