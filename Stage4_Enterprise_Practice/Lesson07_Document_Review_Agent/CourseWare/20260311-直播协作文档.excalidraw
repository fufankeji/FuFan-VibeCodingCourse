    {
      "id": "7s8gXfGnEP7vbWJhOdPw5",
      "type": "text",
      "x": 949.6733503171652,
      "y": 20666.493901950933,
      "width": 659.1798095703125,
      "height": 375,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "#b2f2bb",
      "fillStyle": "hachure",
      "strokeWidth": 1,
      "strokeStyle": "solid",
      "roughness": 0,
      "opacity": 100,
      "groupIds": [],
