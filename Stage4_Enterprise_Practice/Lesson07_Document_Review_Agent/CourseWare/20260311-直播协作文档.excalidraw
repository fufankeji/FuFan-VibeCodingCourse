    {
      "id": "GSuEyoIfs5uZMyMostu0h",
      "type": "text",
      "x": 884.1449288768389,
      "y": 16823.68862910537,
      "width": 699.239990234375,
      "height": 1050,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "#b2f2bb",
      "fillStyle": "hachure",
