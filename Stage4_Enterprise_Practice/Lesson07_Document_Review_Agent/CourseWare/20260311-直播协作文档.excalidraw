    {
      "id": "5PS_d1eRLl6H-snWgY7rR",
      "type": "text",
      "x": 696.9096254076444,
      "y": 8008.242391128615,
      "width": 648,
      "height": 400,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "#b2f2bb",
