    {
      "id": "bj16dy1b3tU5pZUUqmPeT",
      "type": "text",
      "x": 499.371432909144,
      "y": 330.3916162998589,
      "width": 263.23957587171975,
      "height": 68.58796246541695,
      "angle": 0,
