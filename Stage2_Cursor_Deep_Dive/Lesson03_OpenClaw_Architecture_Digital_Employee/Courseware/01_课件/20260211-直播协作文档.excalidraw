    {
      "id": "hpTzOW21soFYWSwWStTPo",
      "type": "text",
      "x": -11.559459574311802,
      "y": 8895.42668065665,
      "width": 599.3919067382812,
      "height": 280,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
