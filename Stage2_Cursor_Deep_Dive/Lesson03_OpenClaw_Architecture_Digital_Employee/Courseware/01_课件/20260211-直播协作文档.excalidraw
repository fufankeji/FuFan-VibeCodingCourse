      "index": "b50",
      "autoResize": true
    },
    {
      "id": "r9nUgWLrQg53Ga6eZSVG9",
      "type": "text",
      "x": 979.8845060730036,
      "y": 3743.1558083602686,
      "width": 375.4273069809062,
      "height": 97.8188555213567,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": "0cMmcUohTAbU82Ls9Bin1",
      "roundness": null,
      "boundElements": [],
      "updated": 1773023644718,
      "link": null,
      "locked": false,
      "versionNonce": 362887897,
      "isDeleted": true,
      "seed": 322257172,
      "text": "传统思维：理解 → 设计 → 开发 → 验证\n\nVibe 思维：运行 → 验证 → 理解 → 设计 → 改造\n\n核心：验证过才值得理解，能跑的代码优于完美的设计",
      "fontSize": 15.65101688341708,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "baseline": 12,
      "containerId": null,
      "originalText": "传统思维：理解 → 设计 → 开发 → 验证\n\nVibe 思维：运行 → 验证 → 理解 → 设计 → 改造\n\n核心：验证过才值得理解，能跑的代码优于完美的设计",
      "lineHeight": 1.25,
      "version": 384,
      "index": "b51",
      "autoResize": true
    },
