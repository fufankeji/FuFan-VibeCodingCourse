      "originalText": "Step 3\n\nOpenClaw 新版本项目本地部署及启动",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
      "id": "yBJr_fb_SvXa838dGJKIT",
      "type": "rectangle",
      "x": 852.0983633185474,
      "y": 2205.6250886010434,
      "width": 558.5887331142831,
      "height": 230.76831831362324,
      "angle": 0,
      "strokeColor": "#1e1e1e",
