    {
      "id": "xvAq4R4bpgCiEgnZvzoF4",
      "type": "text",
      "x": 909.5536316881037,
      "y": 4968.237571477292,
      "width": 513.9598388671875,
      "height": 225,
      "angle": 0,
      "strokeColor": "#1e1e1e",
